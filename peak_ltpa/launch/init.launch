<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="configuration" default="default.yaml" />
    <!--<arg name="mps_file" default="roller_probe.mps" />-->
    <!--<arg name="mps_file" default="Immersion_5MHz_128EL_Long_8_bit_mod.mps" />-->
    <!--<arg name="mps_file" default="Immersion_5MHz_128EL_Long_16_bit_mod.mps" />-->
    <arg name="mps_file" default="Immersion_5MHz_128EL_Long_16_bit_mod.mps" />
    <arg name="rviz" default="true" />


    <group ns="peak">
        <!-- Configuration -->
        <group ns="settings">
            <param name="mps_file" type="string" value="$(arg mps_file)" />
            <rosparam file="$(find peak_ltpa)/config/$(arg configuration)" command="load" />
        </group>
        
        <!-- Peak LTPA Node -->
        <node pkg="peak_ltpa" name="peak_node" type="peak_node" output="screen"/>
        <!--<node pkg="peak_ltpa" name="peak_node" type="peak_node" output="screen" launch-prefix="valgrind"/>-->
    </group>

    <!-- Rviz -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find peak_ltpa)/config/bscan.rviz" if="$(arg rviz)" />

</launch>